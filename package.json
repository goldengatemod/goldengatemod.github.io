{
  "name": "golden-gate-mod",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "start": "node .output/server/index.mjs",
    "dev": "nuxt dev",
    "prod": "pnpm build && pnpm start",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "static:preview": "npx serve .output/public",
    "static:build": "pnpm generate && pnpm static:preview",
    "postinstall": "nuxt prepare",
    "lint": "pnpm lint:eslint && pnpm lint:prettier",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier . --check",
    "lint:fix": "eslint . --fix && prettier --write --list-different .",
    "clean": "rm -rf node_modules .output .nuxt .pnpm-store",
    "clean:install": "pnpm run clean && pnpm install"
  },
  "dependencies": {
    "@iconify-json/flag": "1.2.12",
    "@iconify-json/lucide": "1.2.103",
    "@iconify-json/mdi": "1.2.3",
    "@iconify-json/simple-icons": "1.2.79",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "4.7.0",
    "@nuxtjs/i18n": "10.3.0",
    "@nuxtjs/seo": "5.1.3",
    "nuxt": "4.4.2",
    "nuxt-svgo": "4.2.6",
    "vue": "3.5.33",
    "vue-router": "5.0.6"
  },
  "devDependencies": {
    "@iconify-json/heroicons": "1.2.3",
    "@nuxt/eslint": "1.15.2",
    "@types/node": "25.6.0",
    "eslint": "10.2.1",
    "prettier": "3.8.3",
    "sass-embedded": "1.99.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": "24.15.0"
  },
  "packageManager": "pnpm@10.33.2"
}
